generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  currency        String   @default("NGN")
  role            String   @default("USER")
  lastWorkspaceId String?  @map("last_workspace_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  categories       Category[]
  expenses         Expense[]
  income           Income[]
  budget           Budget[]
  review           Review?
  workspaces       Workspace[]
  workspaceMembers WorkspaceMember[]
  resetToken       String?  @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  refreshToken      String?  @map("refresh_token")
  refreshTokenExpiry DateTime? @map("refresh_token_expiry")

  @@map("users")
}

model Category {
  id        String       @id @default(cuid())
  name      String
  color     String       @default("#6366f1")
  icon      String       @default("wallet")
  type      CategoryType @default(EXPENSE)
  userId    String       @map("user_id")
  workspaceId String      @map("workspace_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  expenses  Expense[]
  income    Income[]
  budget    Budget[]


  @@unique([name, userId])
  @@map("categories")
}

enum CategoryType {
  EXPENSE
  INCOME
  BOTH
}


model Expense {
  id            String        @id @default(cuid())
  title         String
  description   String?
  amount        Decimal       @db.Decimal(12, 2)
  date          DateTime
  paymentMethod PaymentMethod @default(CARD) @map("payment_method")
  notes         String?
  userId        String        @map("user_id")
  workspaceId String      @map("workspace_id")
  categoryId    String        @map("category_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  isRecurring   Boolean  @default(false) @map("is_recurring")

  

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("expenses") 
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOBILE_MONEY
  OTHER
}


model Income {
  id            String        @id @default(cuid())
  title         String
  source        String?
  amount        Decimal       @db.Decimal(12, 2)
  date          DateTime
  userId        String        @map("user_id")
  workspaceId String      @map("workspace_id")
  categoryId    String?        @map("category_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  isRecurring   Boolean  @default(false) @map("is_recurring")


  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])


  @@map("income") 
}


model Budget {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  userId        String        @map("user_id")
  workspaceId String      @map("workspace_id")
  period        String        @default("MONTHLY")
  categoryId    String        @map("category_id")
  lastAlertAt    DateTime? @map("last_alert_at")
  lastAlertType  String?   @map("last_alert_type")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("budgets")
  @@unique([workspaceId, categoryId, period])

}

model Review {
  id        String   @id @default(cuid())
  comment   String
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  type      WorkspaceType @default(PERSONAL)
  ownerId   String        @map("owner_id")
  currency  String        @default("NGN")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  owner      User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members    WorkspaceMember[]
  categories Category[]
  expenses   Expense[]
  income     Income[]
  budgets    Budget[]
  taxProfile TaxProfile?
  portfolio Portfolio?

  @@unique([name, ownerId])
  @@map("workspaces")
}

enum WorkspaceType {
  PERSONAL
  BUSINESS
}


model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}


enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}



model TaxProfile {
  id               String   @id @default(cuid())
  workspaceId      String   @unique @map("workspace_id")
  employmentType   EmploymentType @default(SELF_EMPLOYED) @map("employment_type")
  taxableCategories String[] @map("taxable_categories")

  // Business fields
  businessSector      String?  @map("business_sector")
  businessSize        String?  @map("business_size")
  handlesPaye         Boolean  @default(false) @map("handles_paye")
  vatRegistered       Boolean  @default(false) @map("vat_registered")
  deductibleCategories String[] @map("deductible_categories")

  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("tax_profiles")
}


enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  MIXED
}

model Portfolio {
  id          String     @id @default(cuid())
  workspaceId String     @unique
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  positions   Position[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Position {
  id          String   @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol      String
  name        String
  exchange    String   // NGX or INTERNATIONAL
  currency    String   // NGN or USD
  trades      Trade[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([portfolioId, symbol])
}

model Trade {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  units      Float
  pricePerUnit Float
  totalCost  Float
  buyDate    DateTime
  notes      String?
  createdAt  DateTime @default(now())
}


model StockPrice {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String
  price     Float
  change    Float    @default(0)
  exchange  String   // NGX or INTERNATIONAL
  currency  String   // NGN or USD
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}